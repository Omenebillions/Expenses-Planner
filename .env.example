# OPENAI_API_KEY: Required for OpenAI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
# Important: This key must remain server-side only. Do NOT prefix with VITE_.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
VITE_SUPABASE_URL="https://your-project-url.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
VITE_REVENUECAT_API_KEY="your-revenuecat-public-sku-key"

# Required for AI features proxy
GEMINI_API_KEY="your-gemini-api-key"

# Required for webhook proxy 
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"
# Required for secure database updates from our backend
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Paystack API Keys (For secure local & international invoicing & Android Google Pay integration)
VITE_PAYSTACK_PUBLIC_KEY="your-paystack-live-or-test-public-key"
PAYSTACK_SECRET_KEY="your-paystack-live-or-test-secret-key"
